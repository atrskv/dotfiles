#!/usr/bin/env bash
set -e

DOTFILES="$(cd "$(dirname "$0")" && pwd)"

cd "$DOTFILES"

echo "Starting bootstrap..."

echo "1. Configure apt sources..."
./install -c dotbot-configs/system.conf.yaml

echo "2. Install apt packages..."
sudo ./install -p dotbot-apt/apt.py -c dotbot-configs/packages.conf.yaml

echo "3. Install pipx packages..."
./install -c dotbot-configs/pipx.conf.yaml

echo "4. Install Flatpak apps..."
./install -c dotbot-configs/flatpak.conf.yaml

echo "5. Install fonts..."
./install -c dotbot-configs/fonts.conf.yaml

echo "6. Setup Zsh..."
./install -c dotbot-configs/zsh.conf.yaml

echo "7. Setup TPM..."
./install -c dotbot-configs/tpm.conf.yaml

echo "8. Install Neovim..."
./install -c dotbot-configs/nvim.conf.yaml

echo "9. Install Ghostty..."
./install -c dotbot-configs/ghostty.conf.yaml

echo "10. Install Chrome..."
./install -c dotbot-configs/chrome.conf.yaml

echo "11. Apply dotfiles symlinks..."
./install

echo "Done!"
echo "Log out and log in again if your shell was changed"
echo "Inside tmux, press prefix + I to install tmux plugins"
