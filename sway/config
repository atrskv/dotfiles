include /etc/sway/config-vars.d/*
include /etc/sway/config.d/*
include ~/.config/sway/config.d/*

set $mod Mod4

set $term ghostty
set $menu wofi --show drun --normal-window

set $left h
set $down j
set $up k
set $right l

## KEYBOARD & TOUCHPAD
input * {
    xkb_layout "us,ru"
    xkb_options "grp:alt_shift_toggle,ctrl:swapcaps"
}

input "1739:52908:SYNA30E5:00_06CB:CEAC_Touchpad" {
    natural_scroll enabled
    tap enabled
    tap_button_map lrm
}

## APPEARANCE
gaps inner 13
gaps outer 0
smart_gaps off

default_border          pixel 4
default_floating_border pixel 4
hide_edge_borders       none

client.focused          #b4befe #b4befe #1e1e2e #b4befe #b4befe
client.focused_inactive #1e1e2e #1e1e2e #b4befe #1e1e2e #1e1e2e
client.unfocused        #1e1e2e #1e1e2e #cdd6f4 #1e1e2e #1e1e2e
client.urgent           #f38ba8 #f38ba8 #cdd6f4 #f38ba8 #f38ba8
client.placeholder      #45475a #45475a #888888 #45475a #45475a

## AUTOSTART
# Disabled because waypaper is used:
# output * bg ~/.config/sway/bgs/default.png fill

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec waybar
exec sh -c 'sleep 1s && $HOME/.local/bin/waypaper --restore'

# Enable this block for automatic screen locking:
# exec swayidle -w \
#          timeout 300 'swaylock -f -c 000000' \
#          timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
#          before-sleep 'swaylock -f -c 000000' \
#          lock 'swaylock -f -c 000000'
#

## KEY BINDINGS
bindsym --to-code $mod+Ctrl+l exec loginctl lock-session

bindsym --to-code $mod+Shift+w exec $HOME/.local/bin/waypaper --random

bindsym --to-code $mod+Return exec $term
bindsym --to-code $mod+Shift+q kill
bindsym --to-code $mod+d exec $menu

floating_modifier $mod normal

bindsym --to-code $mod+Shift+c reload

bindsym --to-code $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'

bindsym --to-code $mod+$left focus left
bindsym --to-code $mod+$down focus down
bindsym --to-code $mod+$up focus up
bindsym --to-code $mod+$right focus right

bindsym --to-code $mod+Shift+$left move left
bindsym --to-code $mod+Shift+$down move down
bindsym --to-code $mod+Shift+$up move up
bindsym --to-code $mod+Shift+$right move right

bindsym $mod+Tab workspace back_and_forth

bindsym --to-code $mod+1 workspace number 1
bindsym --to-code $mod+2 workspace number 2
bindsym --to-code $mod+3 workspace number 3
bindsym --to-code $mod+4 workspace number 4
bindsym --to-code $mod+5 workspace number 5
bindsym --to-code $mod+6 workspace number 6
bindsym --to-code $mod+7 workspace number 7
bindsym --to-code $mod+8 workspace number 8
bindsym --to-code $mod+9 workspace number 9

bindsym --to-code $mod+Shift+1 move container to workspace number 1
bindsym --to-code $mod+Shift+2 move container to workspace number 2
bindsym --to-code $mod+Shift+3 move container to workspace number 3
bindsym --to-code $mod+Shift+4 move container to workspace number 4
bindsym --to-code $mod+Shift+5 move container to workspace number 5
bindsym --to-code $mod+Shift+6 move container to workspace number 6
bindsym --to-code $mod+Shift+7 move container to workspace number 7
bindsym --to-code $mod+Shift+8 move container to workspace number 8
bindsym --to-code $mod+Shift+9 move container to workspace number 9

bindsym --to-code $mod+bar splith
bindsym --to-code $mod+minus splitv

bindsym --to-code $mod+s layout stacking
bindsym --to-code $mod+t layout tabbed
bindsym --to-code $mod+b layout toggle split

bindsym --to-code $mod+f fullscreen

bindsym --to-code $mod+Shift+space floating toggle
bindsym --to-code $mod+space focus mode_toggle
bindsym --to-code $mod+a focus parent

### SCRATCHPAD
bindsym --to-code $mod+Shift+grave move scratchpad
bindsym --to-code $mod+grave       scratchpad show

### RESIZE
bindsym --to-code $mod+r mode "resize"

mode "resize" {
    bindsym --to-code $left resize shrink width 10px
    bindsym --to-code $down resize grow height 10px
    bindsym --to-code $up resize shrink height 10px
    bindsym --to-code $right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

### VOLUME
bindsym XF86AudioRaiseVolume exec wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-

bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

### BRIGHTNESS
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

### SCREEN
bindsym --release $mod+p exec flatpak run be.alexandervanhee.gradia --screenshot=FULL
bindsym --release $mod+Shift+p exec flatpak run be.alexandervanhee.gradia --screenshot=INTERACTIVE
